# ===== Required =====
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=your_authentication_key_here

# ===== Server (local dev defaults shown) =====
# In the cloud (Railway/Render/Fly) the Dockerfile sets these for you.
ABHIMATE_HOST=127.0.0.1
ABHIMATE_PORT=5000
ABHIMATE_DEBUG=true

# ===== Browser engine =====
# "selenium" (default) or "playwright"
ABHIMATE_BACKEND=selenium
# Run Chrome without a visible window. MUST be true in the cloud.
ABHIMATE_HEADLESS=false

# ===== Cloud-only (set automatically by the Dockerfile) =====
# Point Selenium at the system Chromium installed in the container.
# CHROME_BIN=/usr/bin/chromium
# CHROMEDRIVER_PATH=/usr/bin/chromedriver

# Public URL — used in Slack notification links so they open the live site.
# ABHIMATE_PUBLIC_URL=https://abhimate.theabhinavsaxena.in
